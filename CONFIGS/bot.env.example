# Copy to CONFIGS/bot.env and fill these in locally.
# Do not commit real tokens or chat ids.

SERVIS_BOT_TOKEN=123456789:replace-with-telegram-bot-token
SERVIS_BOT_ALLOWED_CHAT_IDS=123456789

# Optional. Defaults shown here.
SERVIS_TRAJECTORY_CONFIG=trajectory_kitchen_mesh.json
SERVIS_SERVO_CONFIG=servo_kitchen_mesh.json

# Optional if the bot is started from outside the conda/env you use for SERVIS.
